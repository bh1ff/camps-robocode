generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String   @default("")
  password  String
  role      String   @default("staff")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Season {
  id        String      @id @default(cuid())
  title     String
  slug      String      @unique
  startDate DateTime
  endDate   DateTime
  active    Boolean     @default(true)
  createdAt DateTime    @default(now())
  camps     Camp[]
  priceTiers PriceTier[]
}

model PriceTier {
  id         String  @id @default(cuid())
  days       Int
  pricePence Int
  order      Int     @default(0)
  seasonId   String?
  season     Season? @relation(fields: [seasonId], references: [id])
}

model Location {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @default("")
  address              String   @default("")
  region               String
  imageUrl             String?
  capacityPerDay       Int
  hafSeatsTotal        Int
  allowsPaid           Boolean  @default(false)
  stripeSecretKey      String?
  stripePublishableKey String?
  stripeWebhookSecret  String?
  createdAt            DateTime @default(now())

  camps Camp[]
}

model Camp {
  id              String   @id @default(cuid())
  name            String
  description     String?
  startDate       DateTime
  endDate         DateTime
  active          Boolean  @default(true)
  allowsHaf       Boolean  @default(true)
  allowsPaid      Boolean  @default(false)
  adminPassword   String   @default("admin2026")
  teacherPassword String   @default("teacher2026")
  lunchTime       String   @default("11:45-12:15")
  locationId      String?
  location        Location? @relation(fields: [locationId], references: [id])
  seasonId        String?
  season          Season?   @relation(fields: [seasonId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  groups        Group[]
  areas         Area[]
  sessions      Session[]
  campDays      CampDay[]
  bookings      Booking[]
  bookingTokens BookingToken[]
}

model CampDay {
  id         String   @id @default(cuid())
  date       DateTime
  dayLabel   String
  weekNumber Int
  campId     String
  camp       Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)

  childDays ChildDayBooking[]
}

model Booking {
  id                  String   @id @default(cuid())
  type                String   // "haf" | "paid"
  status              String   @default("pending")
  paymentMethod       String   @default("stripe")

  parentFirstName     String
  parentLastName      String
  parentEmail         String
  parentPhone         String
  address             String
  postcode            String

  hafCode             String?

  totalAmount         Float    @default(0)
  stripeSessionId     String?
  stripePaymentStatus String?

  campId              String
  camp                Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)

  children            Child[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model BookingToken {
  id            String    @id @default(cuid())
  token         String    @unique
  campId        String
  camp          Camp      @relation(fields: [campId], references: [id], onDelete: Cascade)
  paymentMethod String
  parentEmail   String
  parentPhone   String?
  sendMethod    String    @default("email")
  used          Boolean   @default(false)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
}

model Area {
  id     String @id @default(cuid())
  name   String
  type   String
  campId String
  camp   Camp   @relation(fields: [campId], references: [id], onDelete: Cascade)

  scheduleSlots ScheduleSlot[]
}

model Session {
  id     String @id @default(cuid())
  name   String
  time   String
  order  Int
  campId String
  camp   Camp   @relation(fields: [campId], references: [id], onDelete: Cascade)

  scheduleSlots ScheduleSlot[]
  attendances   Attendance[]
}

model Group {
  id       String @id @default(cuid())
  name     String
  color    String @default("blue")
  ageRange String
  campId   String
  camp     Camp   @relation(fields: [campId], references: [id], onDelete: Cascade)

  children      Child[]
  scheduleSlots ScheduleSlot[]
}

model ScheduleSlot {
  id        String @id @default(cuid())
  groupId   String
  sessionId String
  areaId    String

  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  area    Area    @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@unique([groupId, sessionId])
}

model Child {
  id              String    @id @default(cuid())
  firstName       String
  lastName        String
  dateOfBirth     DateTime?
  age             Int

  schoolName      String?
  schoolYear      String?

  hafCode         String?
  fsmEligible     Boolean   @default(true)
  ethnicity       String?
  gender          String?

  hasSEND         Boolean   @default(false)
  hasEHCP         Boolean   @default(false)
  ehcpDetails     String?
  hasAllergies    Boolean   @default(false)
  allergyDetails  String?
  photoPermission Boolean   @default(false)

  bookingId       String?
  booking         Booking?  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  groupId         String?
  group           Group?    @relation(fields: [groupId], references: [id])

  dayBookings     ChildDayBooking[]
  attendances     Attendance[]
}

model ChildDayBooking {
  id         String  @id @default(cuid())
  childId    String
  campDayId  String
  checkedIn  Boolean @default(false)
  checkedOut Boolean @default(false)

  child   Child   @relation(fields: [childId], references: [id], onDelete: Cascade)
  campDay CampDay @relation(fields: [campDayId], references: [id], onDelete: Cascade)

  @@unique([childId, campDayId])
}

model Attendance {
  id        String  @id @default(cuid())
  childId   String
  sessionId String
  attended  Boolean @default(true)

  child   Child   @relation(fields: [childId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([childId, sessionId])
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("website")
  region    String?
  createdAt DateTime @default(now())
}

model Region {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
}
